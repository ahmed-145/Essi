# Supabase — set both to enable real backend; otherwise lib/api.ts mocks.
# Get these from: Supabase dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Sentry — error monitoring (Phase 0). Get from: sentry.io → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog — analytics (Phase 0). Get from: PostHog project → Settings → Project API Key
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Audio CDN: none needed in MVP — audio is served directly from Supabase
# Storage's built-in CDN (v2.2). This var is reserved for the R2 migration
# at scale (see PRD §6.3/§15.5) — leave blank until then.
EXPO_PUBLIC_AUDIO_CDN=
